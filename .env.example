# Copy this file to .env and adjust values for your machine.
# Docs: https://docs.immich.app/install/environment-variables

# Path on your SSD where Immich stores uploaded photos/videos/thumbnails.
UPLOAD_LOCATION=/mnt/c/Rais/immich-data/library

# Path where Postgres stores its data files. Kept on the native WSL2 filesystem
# (not /mnt/c) - Postgres has known locking/fsync issues on DrvFs mounts. The
# WSL2 virtual disk itself still lives on your SSD, so this is not slower.
DB_DATA_LOCATION=/home/raisrb/immich-minigames-data/postgres

# Immich version to run.
IMMICH_VERSION=release

# Postgres credentials used by the immich-server container and exposed on
# localhost:5432 so the minigames backend can connect to Immich's own DB.
DB_PASSWORD=postgres
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Host/port the minigames backend uses to reach that same Postgres. Immich's own
# containers don't need these (they talk to `database` by service name on the
# compose network), but the backend runs on the host and connects via localhost.
# If you're running the backend itself in a container (docker-compose.app.yml), that file
# overrides this to host.docker.internal for you - no need to change it here for that case.
DB_HOST=localhost
DB_PORT=5432

# Base URL the minigames backend uses to call Immich's own REST API (not Postgres, see
# IMMICH_API_KEY below). Same host-vs-container caveat as DB_HOST above.
IMMICH_SERVER_URL=http://localhost:2283

# The role the minigames backend actually connects with (never DB_USERNAME above, which is
# Immich's own admin connection): read-only on Immich's own schema, full control on this app's
# own `minigames` schema. Pick any username/password here - `docker compose -f
# docker-compose.app.yml up` creates/refreshes the role automatically via its `db-init` step
# (backend/src/scripts/bootstrap_db_role.py) before starting the backend. Re-run it standalone
# with `docker compose -f docker-compose.app.yml run --rm db-init` any time you change the
# password below.
DB_APP_USERNAME=minigames_app
DB_APP_PASSWORD=changeme

# API key the minigames backend uses to call Immich's own REST API (not Postgres) to fetch/serve
# thumbnails - direct DB access only gives metadata, not the image bytes. Create one in Immich at
# Account Settings > API Keys, then paste it here.
IMMICH_API_KEY=

# Signs/verifies this app's own login sessions (its own users table - unrelated to Immich's own
# users/auth). Generate with `openssl rand -hex 32`. Keep secret; rotating it logs everyone out.
JWT_SECRET=

# Uncomment to pin a timezone (list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
# TZ=America/Santiago

# --- docker-compose.app.yml only (packaged backend/frontend images, not the dev Immich stack) ---

# Image tag to pull for the minigames backend/frontend from GHCR: "edge" (latest main commit),
# "latest" (newest vX.Y.Z release), or a specific "X.Y.Z"/"X.Y" version.
MINIGAMES_VERSION=edge

# Host port to reach the minigames frontend on.
FRONTEND_PORT=3000
